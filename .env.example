# =============================================================================
# ShipSmart - Local Development Environment
# =============================================================================
# Copy this file to .env and fill in your values

# Firebase Admin SDK
FIREBASE_PROJECT_ID=shipsmart-app-dev
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS - Allow local frontend dev server
ALLOWED_ORIGINS=http://localhost:5173

# Shopify (for future integration)
SHOPIFY_STORE_URL=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_SHARED_SECRET=

# Redis (for caching) - optional for local dev
REDIS_URL=redis://localhost:6379

# API Keys for service-to-service auth (format: service:key,service:key)
API_KEYS=
