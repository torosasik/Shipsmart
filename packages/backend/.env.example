# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Server
PORT=3001
NODE_ENV=development

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Webhook Verification
SHOPIFY_SHARED_SECRET=
CARRIER_WEBHOOK_SECRET_FEDEX=
CARRIER_WEBHOOK_SECRET_UPS=
CARRIER_WEBHOOK_SECRET_USPS=

# Redis (optional, for caching)
REDIS_URL=

# Veeqo
VEEQO_API_KEY=your-veeqo-api-key
# Set to true to generate test labels
VEEQO_TEST_MODE=false

# ShipStation
SHIPSTATION_API_KEY=OzL0W34yO21C5xnRduRbe8WWusbKUcNc4qSrL5G/jjk
SHIPSTATION_API_SECRET=your-shipstation-api-secret
# Default carrier code for rate shopping (e.g. stamps_com, fedex, ups, usps)
SHIPSTATION_DEFAULT_CARRIER=stamps_com
# Set to true to generate test labels (non-billable)
SHIPSTATION_TEST_MODE=false
